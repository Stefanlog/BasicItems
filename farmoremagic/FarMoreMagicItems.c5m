icon "far_more_magic_items.png"
description "A massive expansion of the item pool, featuring sentient armor that abandons you in battle, 'tactical' pocketsand, stone tablets that offer dubious moral advice, a stick that summons a frog every time you hit someone with it, and a spider that will sit on your head acting as a helmet if you don't mind losing an ear or two."

newweapon "Acidic Towershield"
        trgrank  1
        range 1
        init 2
        mundane
        dmgtype 2
        sound 11
        dmg 3
        aoe 0

newitem "Acidic Towershield"
	spr "fmmisprites/acidictowershield.tga"
        rarity 0
        type 1
        itemwep "Acidic Towershield"
        largeshield
        acidres 75
        acidblood 50
        descr "A heavy towershield coated in acid. Heavy enough that a good shieldbash hurts, but the true value comes from hunkering down behind it and letting the acid do its part."

newitem "Alchemist's Coat"
        spr "fmmisprites/alchemistscoat.tga"
        rarity 0
        type 4
        armor 1
        hp 3
        acidres 100
        poisonres 75
        fireres 50
        descr "After an untold number of failed experiments, this coat has endured acids, flames, and poisons that should have destroyed it thrice over."

newitem "Apple of Discord"  
        spr "fmmisprites/applediscord.tga"  
        rarity 0  
        type 7    
        confusionaura 2
        descr "A golden apple thrown by the goddess Eris to spark strife. Merely holding it sows calamity, spreading confusion and making friends attack each other. Handle with extreme care."

newitem "Argus"
	spr "fmmisprites/argus.tga"
        rarity 0
        type 7
        magicshield
        extraeyes 13
        acutesenses
        descr "A towershield that binds to your back, leaving your hands free but your mind no longer your own. The shield’s many eyes scan the horizon, flooding your consciousness with a thousand overlapping views."

newitem "Assassin's Contract"
        spr "fmmisprites/assassinscontract.tga"
        rarity 0
        type 7
        stealth
        combatsum -1 "1*Shadow Stalker"
descr "Your signature seals it. An unseen blade joins your fights, and watches your back a little too closely."

newitem "Banner of the Last Stand"
        spr "fmmisprites/laststandbanner.tga"
        rarity 0
        type 7
        morale 2
        awe 2
        hp 3
        localleadership 10
        descr "Raised only when retreat is impossible and death is certain. Somehow, it turns certain death into a fighting chance. Soldiers who rally to it discover reserves of courage they never knew they had."

newitem "Black Rose"
        spr "fmmisprites/blackrose.tga"
        rarity 0
        type 7
        combatsum -1 "Black Rose"
        descr "A perfectly black rose. Who should you give it to?"

newitem "Blessed Salt"
        spr "fmmisprites/blessedsalt.tga"
        rarity 0
        type 7
        combatspell 1 "Banish"
        diseaseres
        charmres
        descr "Simple salt, sanctified a thousand times. It wards against corruption, disease, and dark magic. Keep it close, or throw it at the demons in front of you, to banish them once and for all."

newitem "Blessed Sandals"
        spr "fmmisprites/blessedsandals.tga"
        rarity 0
        type 6
        hp 2
        fastheal
        holy
        descr "These sandals carry quite a strong blessing. Where they tread, grass grows. Wounds close faster, and the wearer feels more vigorous."

newweapon "Blight"
        trgrank 1
        range 1
        init 6
        dmgtype 1
        sound 8
        dmg 10
        ghoulify
